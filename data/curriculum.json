                "Back-substitute to express the result in x"
              ]
            }
          ]
        },
        {
          "id": "calc-u7",
          "title": "Unit 7 \u2014 Definite Integrals",
          "topics": [
            {
              "id": "calc-u7-t1",
              "title": "Riemann sums and the definite integral",
              "difficulty": 4,
              "prerequisites": ["calc-u6-t1"],
              "domain_affinity": ["structural_engineering", "epidemiology"],
              "objectives": [
                "Approximate area using left/right/midpoint sums",
                "Take the limit as n \u2192 \u221e",
                "Interpret integrals as accumulated change"
              ]
            },
            {
              "id": "calc-u7-t2",
              "title": "Fundamental Theorem of Calculus",
              "difficulty": 4,
              "prerequisites": ["calc-u7-t1"],
              "domain_affinity": ["structural_engineering"],
              "objectives": [
                "Apply FTC parts 1 and 2",
                "Evaluate definite integrals with antiderivatives",
                "Differentiate integrals with variable bounds"
              ]
            }
          ]
        },
        {
          "id": "calc-u8",
          "title": "Unit 8 \u2014 Applications of Integration",
          "topics": [
            {
              "id": "calc-u8-t1",
              "title": "Area between curves and average value",
              "difficulty": 4,
              "prerequisites": ["calc-u7-t2"],
              "domain_affinity": ["architecture", "sports_analytics"],
              "objectives": [
                "Set up integrals for area between curves",
                "Compute average value of a function",
                "Interpret results in context"
              ]
            },
            {
              "id": "calc-u8-t2",
              "title": "Volumes of revolution (disk/washer/shell)",
              "difficulty": 5,
              "prerequisites": ["calc-u8-t1"],
              "domain_affinity": ["architecture", "structural_engineering"],
              "objectives": [
                "Set up disk and washer integrals",
                "Apply the shell method when appropriate",
                "Compare methods on the same solid"
              ]
            }
          ]
        },
        {
          "id": "calc-u9",
          "title": "Unit 9 \u2014 Transcendental Functions",
          "topics": [
            {
              "id": "calc-u9-t1",
              "title": "Derivatives and integrals of exponentials and logs",
              "difficulty": 4,
              "prerequisites": ["calc-u4-t1", "alg-u9-t2"],
              "domain_affinity": ["personal_finance", "epidemiology"],
              "objectives": [
                "Differentiate e^x, a^x, ln x, log_a x",
                "Integrate 1/x and e^x",
                "Solve exponential-decay/growth problems"
              ]
            },
            {
              "id": "calc-u9-t2",
              "title": "Derivatives and integrals of trig functions",
              "difficulty": 4,
              "prerequisites": ["calc-u4-t1", "calc-u1-t2"],
              "domain_affinity": ["game_development", "sports_analytics"],
              "objectives": [
                "Differentiate and integrate sin, cos, tan and friends",
                "Combine with chain rule and u-substitution",
                "Apply to oscillatory real-world problems"
              ]
            }
          ]
        },
        {
          "id": "calc-capstone-unit",
          "title": "Capstone \u2014 Reservoir Design",
          "topics": [
            {
              "id": "calc-capstone",
              "title": "Structural optimization capstone",
              "difficulty": 5,
              "prerequisites": [
                "calc-u2-t2",
                "calc-u5-t1",
                "calc-u5-t2",
                "calc-u7-t2",
                "calc-u8-t2",
                "calc-u9-t2"
              ],
              "domain_affinity": ["structural_engineering", "architecture"],
              "objectives": [
                "Analyze boundary flow with limits",
                "Optimize cross-section using derivatives",
                "Model variable inflow with related rates",
                "Compute total volume and material with definite integrals",
                "Produce a design recommendation with cost estimate"
              ]
            }
          ]
        }
      ]
    }
  ]
}
