# ============================================================================
# Aegis 2 — .gitignore
# ============================================================================

# ---- USER DATA (never commit) ----------------------------------------------
# data/userdata.db contains the encrypted API key, every session, every chat
# message, mastery scores, and the capstone scratchpad. data/curriculum.json
# is shipped with the app and SHOULD be committed.
data/userdata.db
data/userdata.db-shm
data/userdata.db-wal
data/userdata.db.bak
# Diagnostic dumps that may be written next to the DB during development.
data/_*.txt
data/aegis2_*.db

# ---- Python ----------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
.tox/

# ---- Virtual environments --------------------------------------------------
venv/
.venv/
env/
ENV/

# ---- PyInstaller -----------------------------------------------------------
# Build intermediate + final bundle. Use GitHub Releases for binaries instead
# of committing 50-100 MB of bundled dist into the repo.
build/
dist/

# ---- Frontend (Node / Vite) ------------------------------------------------
frontend/node_modules/
frontend/dist/
frontend/.vite/
# Compiled frontend that PyInstaller picks up — regenerated by `npm run build`.
static/

# Lockfiles are deliberately NOT ignored:
#   frontend/package-lock.json  -> commit this for reproducible builds
#   requirements.txt            -> already tracked

# ---- Node logs / misc ------------------------------------------------------
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/

# ---- OS metadata -----------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# ---- Editor / IDE ----------------------------------------------------------
# If your team agrees to share an IDE config, drop the relevant entry here.
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
*.swp
*.swo
*~
.history/

# ---- Local env / secrets ---------------------------------------------------
.env
.env.local
.env.*.local
*.pem
*.key
secrets.json
